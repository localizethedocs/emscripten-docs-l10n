#: ../../../source/docs/tools_reference/emcmdprompt.rst:5
msgid "Emscripten Windows Command Prompt (emcmdprompt.bat)"
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:7
msgid ""
"The *Emscripten Command Prompt* is used to call Emscripten tools from the "
"command line on Windows."
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:9
msgid ""
"The prompt can be launched from the file system by locating and opening the "
"file **emcmdprompt.bat**."
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:11
msgid ""
"The *Emscripten Command Prompt* is configured with the correct system paths "
"and settings to point to the :term:`active <Active Tool/SDK>` Emscripten "
"tools. From within the prompt you can call :ref:`emsdk <emsdk>` to change "
"the current SDK or tools."
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:16
msgid "Command line syntax"
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:18
msgid ""
"The tool is not *intended* to be run from an existing command line prompt."
msgstr ""

#: ../../../source/docs/tools_reference/emcmdprompt.rst:20
msgid ""
"However, if **emcmdprompt.bat** is called on the command line, a nested "
"Emscripten command prompt is spawned within the current prompt (note that "
"this is not necessarily obvious). You can then use this prompt to access the "
"SDK tools. To exit the nested command prompt, type **exit** and then press "
"the **Enter** key."
msgstr ""
