msgid "Const"
msgstr ""

#: ../../../source/docs/porting/connecting_cpp_and_javascript/WebIDL-Binder.rst:248
msgid ""
"C++ arguments or return types that use ``const`` can be specified in IDL "
"using ``[Const]``."
msgstr ""

