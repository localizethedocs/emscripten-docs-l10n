#: ../../../source/docs/tools_reference/settings_reference.rst:2216
#: ../../../source/docs/tools_reference/settings_reference.rst:2227
#: ../../../source/docs/tools_reference/settings_reference.rst:2395
#: ../../../source/docs/tools_reference/settings_reference.rst:2577
#: ../../../source/docs/tools_reference/settings_reference.rst:2703
msgid "Default value: 1"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:33
msgid "STACK_OVERFLOW_CHECK"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:35
msgid ""
"Chooses what kind of stack smash checks to emit to generated code: Building "
"with ASSERTIONS=1 causes STACK_OVERFLOW_CHECK default to 1. Since "
"ASSERTIONS=1 is the default at -O0, which itself is the default optimization "
"level this means that this setting also effectively defaults to 1, absent "
"any other settings:"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:41
msgid "0: Stack overflows are not checked."
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:42
msgid ""
"1: Adds a security cookie at the top of the stack, which is checked at end "
"of each tick and at exit (practically zero performance overhead)"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:44
msgid ""
"2: Same as above, but also runs a binaryen pass which adds a check to all "
"stack pointer assignments. Has a small performance cost."
msgstr ""

