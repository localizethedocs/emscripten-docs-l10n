msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:1466
msgid "preinitializedWebGLContext"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:1467
msgid "keyboardListeningElement"
msgstr ""

#: ../../../source/docs/tools_reference/settings_reference.rst:1468
msgid "doNotCaptureKeyboard"
msgstr ""

